{
  "name": "korrekturleser",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "check": "run-p format lint types spell test knip",
    "cy:open": "cypress open --e2e",
    "cy:run": "cypress run --e2e",
    "dev": "vite",
    "format": "biome check --write .",
    "generate-api": "openapi-ts && uv run python scripts/gen_mode_descriptions.py",
    "lint": "eslint . --cache --fix --ignore-pattern .gitignore",
    "preview": "vite preview",
    "run": "run-s build preview",
    "spell": "cspell-cli --cache --quiet --gitignore --unique .",
    "test-cov": "vitest --watch=false --coverage",
    "test": "vitest --watch=false",
    "types": "vue-tsc --build",
    "knip": "knip"
  },
  "dependencies": {
    "@quasar/extras": "^1.18.0",
    "axios": "^1.16.1",
    "diff": "^9.0.0",
    "diff2html": "^3.4.56",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "workbox-window": "^7.4.1"
  },
  "browserslist": [
    "iOS >= 15",
    "Safari >= 15",
    "> 0.5%",
    "not dead"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@cspell/dict-de-de": "^4.1.2",
    "@hey-api/openapi-ts": "0.97.2",
    "@quasar/vite-plugin": "^1.12.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.18",
    "@vue/tsconfig": "^0.9.1",
    "cspell-cli": "^10.0.0",
    "cypress": "^15.16.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-vue": "~10.9.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "markdownlint-cli2": "^0.22.1",
    "npm-run-all2": "^9.0.1",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.3"
  }
